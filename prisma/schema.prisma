generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Condition {
  id          String   @id @default(uuid())
  name        String   @unique
  description String   @default("")
  cueConfig   String   // JSON: { agentName, agentTone, confidenceFraming, ... }
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  participants Participant[]
}

model Participant {
  id            String   @id @default(uuid())
  externalId    String   @unique // human-readable participant code
  conditionId   String
  demographics  String   @default("{}") // JSON
  status        String   @default("consent") // consent | demographics | instructions | experiment | survey | completed | abandoned
  currentTrial  Int      @default(0)
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  consentedAt   DateTime?
  userAgent     String   @default("")
  ipHash        String   @default("") // hashed for privacy

  condition      Condition       @relation(fields: [conditionId], references: [id])
  trials         Trial[]
  events         Event[]
  trustResponses TrustResponse[]

  @@index([conditionId])
  @@index([status])
}

model Trial {
  id                      String   @id @default(uuid())
  participantId           String
  trialNumber             Int
  scenarioId              String
  isPractice              Boolean  @default(false)
  scenarioData            String   // JSON: the full scenario shown to participant
  aiRecommendation        String   // "approve" | "reject"
  aiConfidenceDisplay     String   // the confidence text shown (varies by condition)
  aiIsCorrect             Boolean
  correctAnswer           String   // "approve" | "reject"
  participantDecision     String   // "accept" | "override"
  participantOverride     String?  // if overridden, what they chose
  confidenceRating        Int?     // 1-5 optional self-reported confidence
  decisionLatencyMs       Int      // time from scenario display to decision
  totalTrialDurationMs    Int      // full trial duration including confidence rating
  timestamp               DateTime @default(now())

  participant Participant @relation(fields: [participantId], references: [id])

  @@unique([participantId, trialNumber])
  @@index([participantId])
  @@index([scenarioId])
}

model Event {
  id            String   @id @default(uuid())
  participantId String
  eventType     String   // page_view | decision_hover | decision_change | task_start | task_end | etc.
  payload       String   @default("{}") // JSON: flexible event-specific data
  timestamp     DateTime @default(now())

  participant Participant @relation(fields: [participantId], references: [id])

  @@index([participantId])
  @@index([eventType])
  @@index([timestamp])
}

model TrustResponse {
  id            String   @id @default(uuid())
  participantId String
  scaleName     String   // e.g. "trust_in_automation"
  itemIndex     Int
  itemText      String
  response      Int      // Likert scale value
  timestamp     DateTime @default(now())

  participant Participant @relation(fields: [participantId], references: [id])

  @@unique([participantId, scaleName, itemIndex])
  @@index([participantId])
}
